<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>
    <property>
        <name>yarn.federation.enabled</name>
        <value>true</value>
    </property>

    <property>
        <name>yarn.federation.failover.enabled</name>
        <value>false</value>
    </property>

    <property>
        <name>yarn.federation.non-ha.enabled</name>
        <value>true</value>
    </property>

    <property>
        <name>yarn.federation.state-store.class</name>
        <value>org.apache.hadoop.yarn.server.federation.store.impl.ZookeeperFederationStateStore</value>
    </property>

    <property>
        <name>hadoop.zk.address</name>
        <value>nn1.lab.example.com:2181</value>
    </property>

    <property>
        <name>yarn.router.bind-host</name>
        <value>0.0.0.0</value>
    </property>

    <property>
        <name>yarn.router.hostname</name>
        <value>router1.lab.example.com</value>
    </property>

    <property>
        <name>yarn.router.clientrm.address</name>
        <value>router1.lab.example.com:8050</value>
    </property>

    <property>
        <name>yarn.router.admin.address</name>
        <value>router1.lab.example.com:8052</value>
    </property>

    <property>
        <name>yarn.router.webapp.address</name>
        <value>router1.lab.example.com:8089</value>
    </property>

    <property>
        <name>yarn.router.keytab.file</name>
        <value>/etc/security/keytabs/router.service.keytab</value>
    </property>

    <property>
        <name>yarn.router.kerberos.principal</name>
        <value>router/_HOST@EXAMPLE.COM</value>
    </property>

    <property>
        <name>yarn.router.clientrm.interceptor-class.pipeline</name>
        <value>org.apache.hadoop.yarn.server.router.clientrm.PassThroughClientRequestInterceptor,
            org.apache.hadoop.yarn.server.router.clientrm.ApplicationSubmissionContextInterceptor,
            org.apache.hadoop.yarn.server.router.clientrm.FederationClientInterceptor</value>
    </property>

    <property>
        <name>yarn.router.asc-interceptor-max-size</name>
        <value>1MB</value>
    </property>

    <property>
        <name>yarn.router.rmadmin.interceptor-class.pipeline</name>
        <value>org.apache.hadoop.yarn.server.router.rmadmin.FederationRMAdminInterceptor</value>
    </property>

    <property>
        <name>yarn.router.webapp.interceptor-class.pipeline</name>
        <value>org.apache.hadoop.yarn.server.router.webapp.FederationInterceptorREST</value>
    </property>

    <property>
        <name>yarn.router.interceptor.allow-partial-result.enable</name>
        <value>true</value>
    </property>

    <property>
        <name>yarn.router.deregister.subcluster.enable</name>
        <value>true</value>
    </property>

    <property>
        <name>yarn.router.subcluster.heartbeat.expiration.time</name>
        <value>5m</value>
    </property>

    <property>
        <name>yarn.router.subcluster.cleaner.interval.time</name>
        <value>30s</value>
    </property>

    <property>
        <name>yarn.federation.cache-ttl.secs</name>
        <value>60</value>
    </property>
</configuration>
